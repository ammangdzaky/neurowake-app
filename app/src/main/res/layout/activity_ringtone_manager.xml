<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/audio_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COLLECTION"
            android:textColor="@color/accent_cyan"
            android:textSize="12sp"
            android:letterSpacing="0.2"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_ringtone_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Audio Library"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_ringtone_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Select multiple tracks. NeuroWake will pick one at random to wake you up."
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Empty State / List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_ringtones"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/audio_header" />

    <!-- Bottom Action Area -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_dark"
        app:cardElevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_add_local_file"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_margin="24dp"
            android:text="IMPORT AUDIO"
            android:textAllCaps="true"
            android:textColor="@color/bg_dark"
            android:textStyle="bold"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/accent_cyan"
            app:icon="@android:drawable/ic_menu_add"
            app:iconGravity="textStart"
            app:iconTint="@color/bg_dark" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>